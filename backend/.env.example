# Flask Configuration
FLASK_ENV=development
FLASK_APP=run.py
SECRET_KEY=replace_with_a_secure_random_string_in_production
PORT=5000

# Firebase Configuration
# Path to your Firebase service account JSON key file
FIREBASE_CREDENTIALS_PATH=config/firebase-key.json
# Your Firebase Storage Bucket Name (e.g., your-project-id.appspot.com or your-project-id.firebasestorage.app)
FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app

# AI Service Configuration
# Your Groq API key (from console.groq.com)
GROQ_API_KEY=gsk_your_groq_api_key_here
